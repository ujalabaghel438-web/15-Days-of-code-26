#include<iostream>
using namespace std;
void sort(int arr[] ,int n,int i)
{
    if(i==n) return ;
    int target=arr[i];
    int j=i-1;
    while(j>=0 && arr[j]>target)
    {
        
        arr[j+1]=arr[j];
        j--;
    }
    arr[j+1]=target;
    return sort(arr,n,i+1);
}
int main()
{
    int n;
    cin>>n;
    int arr[n];
    for(int i=0;i<n;i++) cin>>arr[i];
    sort(arr,n,1);
    cout<<endl;
    for(int i=0;i<n;i++) cout<<arr[i]<<" ";
}
